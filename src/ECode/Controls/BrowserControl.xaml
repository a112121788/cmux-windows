<UserControl x:Class="ECode.Controls.BrowserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 浏览器工具栏 -->
        <Grid Grid.Row="0" Background="{StaticResource SurfaceTabBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="BackButton"
                    Content="&#xE72B;" FontFamily="Segoe MDL2 Assets"
                    Style="{StaticResource ECodeButton}" Click="Back_Click"
                    Width="32" Height="28" Padding="0" Margin="4,0,0,0" FontSize="12" />

            <Button Grid.Column="1" x:Name="ForwardButton"
                    Content="&#xE72A;" FontFamily="Segoe MDL2 Assets"
                    Style="{StaticResource ECodeButton}" Click="Forward_Click"
                    Width="32" Height="28" Padding="0" FontSize="12" />

            <Button Grid.Column="2" x:Name="ReloadButton"
                    Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                    Style="{StaticResource ECodeButton}" Click="Reload_Click"
                    Width="32" Height="28" Padding="0" FontSize="12" />

            <!-- 地址栏 -->
            <Border Grid.Column="3" CornerRadius="6" Margin="4"
                    Background="{StaticResource SurfaceHighBrush}">
                <TextBox x:Name="AddressBar"
                         Background="Transparent" Foreground="{StaticResource ForegroundBrush}"
                         CaretBrush="{StaticResource AccentBrush}"
                         BorderThickness="0" FontSize="12" Padding="8,4"
                         VerticalContentAlignment="Center"
                         KeyDown="AddressBar_KeyDown" />
            </Border>

            <Button Grid.Column="4" Content="&#xE10A;" FontFamily="Segoe MDL2 Assets"
                    Style="{StaticResource ECodeButton}" Click="CloseBrowser_Click"
                    Width="32" Height="28" Padding="0" Margin="0,0,4,0" FontSize="10" />
        </Grid>

        <Grid Grid.Row="1">
            <!-- WebView2 -->
            <wv2:WebView2 x:Name="WebView"
                          NavigationStarting="WebView_NavigationStarting"
                          NavigationCompleted="WebView_NavigationCompleted"
                          SourceChanged="WebView_SourceChanged" />

            <Border x:Name="ErrorOverlay"
                    Visibility="Collapsed"
                    Background="{StaticResource BackgroundBrush}"
                    Padding="32">
                <StackPanel MaxWidth="520" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="无法启动内置浏览器"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ForegroundBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="ErrorMessageText"
                               TextWrapping="Wrap"
                               Margin="0,12,0,16"
                               Foreground="{StaticResource ForegroundDimBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <Button Content="下载 WebView2 Runtime"
                            Style="{StaticResource ECodeButton}"
                            HorizontalAlignment="Center"
                            Padding="14,8"
                            Click="DownloadWebView2_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
